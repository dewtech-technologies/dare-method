{
  "name": "@dewtech/dare-graphrag",
  "version": "0.3.2",
  "description": "DARE Framework GraphRAG - Knowledge graph with SQLite persistence and FTS5 search",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@dewtech/dare-core": "workspace:*",
    "chalk": "^5.3.0",
    "fs-extra": "^11.1.1",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.1",
    "@types/node": "^20.0.0",
    "@types/sql.js": "^1.4.9",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "dare",
    "graphrag",
    "knowledge-graph",
    "sqlite",
    "semantic-search"
  ],
  "author": "Dewtech Technologies",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dewtech-technologies/dare-method.git",
    "directory": "packages/graphrag"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
