{
  "name": "@dewtech/dare-mcp-server",
  "version": "0.3.5",
  "description": "DARE Framework MCP Server - Model Context Protocol server for AI-assisted development",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "dare-mcp-server": "./dist/bin/server.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/bin/server.ts",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@dewtech/dare-core": "^0.3.5",
    "chalk": "^5.3.0",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "fs-extra": "^11.1.1",
    "js-yaml": "^4.1.0",
    "pino": "^8.16.0",
    "pino-pretty": "^10.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.0",
    "@types/fs-extra": "^11.0.1",
    "@types/js-yaml": "^4.0.5",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "dare",
    "mcp",
    "model-context-protocol",
    "ai-assisted"
  ],
  "author": "Dewtech Technologies",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dewtech-technologies/dare-method.git",
    "directory": "packages/mcp-server"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
