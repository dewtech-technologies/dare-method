{
  "name": "@dewtech/dare-cli",
  "version": "2.5.0",
  "description": "DARE Framework - CLI, GraphRAG engine, MCP server and shared types in a single package",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "dare": "./dist/bin/dare.js",
    "dare-mcp-server": "./dist/mcp-server/bin/server.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "sync": "tsx scripts/sync-implementations.ts",
    "build": "tsx scripts/sync-implementations.ts && tsc",
    "dev": "tsx watch src/bin/dare.ts",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "fs-extra": "^11.1.1",
    "inquirer": "^9.2.0",
    "js-yaml": "^4.1.0",
    "ora": "^7.0.1",
    "pino": "^8.16.0",
    "pino-pretty": "^10.2.0",
    "sql.js": "^1.11.0",
    "yaml": "^2.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.0",
    "@types/fs-extra": "^11.0.1",
    "@types/inquirer": "^9.0.3",
    "@types/js-yaml": "^4.0.5",
    "@types/node": "^20.0.0",
    "@types/sql.js": "^1.4.9",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "dare",
    "cli",
    "ai-assisted",
    "development",
    "mcp",
    "knowledge-graph",
    "graphrag",
    "model-context-protocol"
  ],
  "author": "Dewtech Technologies",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dewtech-technologies/dare-method.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
