APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_PORT=8000

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=myapi
DB_USERNAME=user
DB_PASSWORD=pass

CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost:3000

BCRYPT_ROUNDS=12

# Reverb (WebSocket)
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=myapp
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

# Rate limit
RATE_LIMIT_PER_MIN=60

# LLM provider
LLM_PROVIDER=dummy
# OPENAI_API_KEY=
