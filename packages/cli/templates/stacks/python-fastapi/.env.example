# Application
APP_PORT=8000
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/myapi

# JWT auth
JWT_SECRET=replace-me-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRES_MIN=15

# Password hashing
BCRYPT_ROUNDS=12

# Rate limit
RATE_LIMIT_PER_MIN=60

# LLM provider (optional)
# LLM_PROVIDER=dummy
# OPENAI_API_KEY=
