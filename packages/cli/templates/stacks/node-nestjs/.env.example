# Application
PORT=3000
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/myapi

# JWT auth
JWT_SECRET=replace-me-in-prod
JWT_EXPIRES_IN=15m

# Password hashing
BCRYPT_COST=12

# Throttler (rate limit)
RATE_LIMIT_RPM=60
RATE_LIMIT_TTL=60

# LLM provider (optional)
# LLM_PROVIDER=dummy
# OPENAI_API_KEY=
