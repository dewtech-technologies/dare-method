# Application
APP_PORT=8000
RUST_LOG=info

# Database
DATABASE_URL=postgres://user:pass@localhost:5432/myapi

# JWT auth
JWT_SECRET=replace-me-in-prod
JWT_EXPIRES_SECS=900

# Argon2 (uses sensible defaults; tune for production)
ARGON2_MEM_KIB=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# Rate limit
RATE_LIMIT_PER_SEC=10
RATE_LIMIT_BURST=20

# CORS — comma-separated origins (NEVER use *)
CORS_ORIGINS=http://localhost:3000

# LLM provider (optional)
LLM_PROVIDER=dummy
# OPENAI_API_KEY=
