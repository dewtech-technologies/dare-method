# MCP transport — overrides --transport flag if set
# Valid: stdio | sse | http
MCP_TRANSPORT=stdio

# HTTP/SSE transport port (ignored on stdio)
MCP_PORT=3001

# Rate limit (HTTP/SSE only — stdio is single-client local)
RATE_LIMIT_RPM=120

# Logging
LOG_LEVEL=info

# LLM provider (optional — for tools that call out)
LLM_PROVIDER=dummy
# OPENAI_API_KEY=
