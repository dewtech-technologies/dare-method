{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(npm run build)",
      "Bash(npm test)",
      "Bash(npx eslint src)",
      "Bash(dare:*)",
      "Read(DARE/**)",
      "Write(DARE/**)",
      "Read(src/**)",
      "Write(src/**)",
      "Read(.claude/**)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Write(.env)",
      "Write(.env.local)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "dare hooks run on-save --file \"$CLAUDE_FILE_PATHS\""
          }
        ]
      }
    ]
  }
}
