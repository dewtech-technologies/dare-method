# Exemplo de Dockerfile para Laravel 11 (PHP 8.3)
# Baseado em melhores práticas de containerização

# Estágio 1: Composer (Build)
FROM composer:2.7 AS build

WORKDIR /app
COPY composer.json composer.lock ./
RUN composer install --no-scripts --no-autoloader --ignore-platform-reqs

COPY . .
RUN composer dump-autoload --optimize

# Estágio 2: PHP-FPM (Runtime)
FROM php:8.3-fpm-alpine

# Instalar dependências do sistema e extensões PHP
RUN apk add --no-cache \
    linux-headers \
    libzip-dev \
    zip \
    unzip \
    git \
    curl \
    libpng-dev \
    oniguruma-dev \
    libxml2-dev \
    postgresql-dev \
    && docker-php-ext-install pdo_pgsql mbstring exif pcntl bcmath gd \
    && apk del linux-headers

# Configurar diretório de trabalho
WORKDIR /var/www/html

# Copiar arquivos do estágio de build
COPY --from=build /app /var/www/html

# Ajustar permissões para o usuário www-data
RUN chown -R www-data:www-data /var/www/html \
    && chmod -R 775 /var/www/html/storage \
    && chmod -R 775 /var/www/html/bootstrap/cache

# Mudar para usuário não-root
USER www-data

# Expor a porta do PHP-FPM
EXPOSE 9000

# Iniciar o PHP-FPM
CMD ["php-fpm"]
